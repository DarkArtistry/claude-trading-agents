# Anthropic (console.anthropic.com — separate from claude.ai Team plan)
ANTHROPIC_API_KEY=

# Binance testnet (testnet.binance.vision)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Mainnet interlock — both must flip to go live.
BINANCE_USE_TESTNET=true
I_UNDERSTAND_MAINNET=no

# Trading universe (comma-separated ccxt symbols) and candle timeframe.
UNIVERSE=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT
TIMEFRAME=5m
DRY_RUN=true

# Journal / agent-id cache
DB_PATH=./data/journal.db
AGENT_CACHE_PATH=./data/agent-cache.json
LOG_LEVEL=info

# MCP server — the PM agent in Anthropic's container talks to this.
# Expose via a tunnel:  cloudflared tunnel --url http://localhost:3333
# Then paste the https URL into MCP_PUBLIC_URL below.
MCP_PORT=3333
MCP_AUTH_TOKEN=change-me-dev-token-please
MCP_PUBLIC_URL=

# Models
PM_MODEL=claude-opus-4-6
SUB_AGENT_MODEL=claude-sonnet-4-6
